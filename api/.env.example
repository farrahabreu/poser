PORT=3001
JWT_SECRET=change_me_to_64_random_bytes_hex_string_here_abcdef1234567890abcdef
JWT_REFRESH_SECRET=another_64_random_bytes_hex_string_here_abcdef1234567890fedcba
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@poser.app
DB_PATH=./db/poser.db
UPLOAD_DIR=./uploads
MAX_AUDIO_MB=20
ALLOWED_ORIGIN=http://localhost:8080
NODE_ENV=development

# ── External media APIs (Tracking feature) ──────────────────────────────────
# TMDB (cinema search) — get a free key at https://www.themoviedb.org/settings/api
# Use a Read Access Token (v4 auth Bearer token), not the v3 API key string.
TMDB_API_KEY=
# Spotify (music enrichment, optional) — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# OpenLibrary and MusicBrainz are open APIs — no keys required.
